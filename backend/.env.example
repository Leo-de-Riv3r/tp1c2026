# Copiar este archivo como .env y completar los valores
# NUNCA subir .env al repositorio

# Para desarrollo local sin Docker, MongoDB no requiere credenciales
# Descomentar y completar cuando se use Docker o cloud:
# MONGO_USERNAME=
# MONGO_PASSWORD=
# SPRING_DATA_MONGODB_URI=mongodb://usuario:password@localhost:27017/tacs_db

# Para desarrollo local sin credenciales:
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/tacs_db
MONGO_DATABASE=tacs_db

# Para auth (cuando se implemente):
JWT_SECRET=
ADMIN_PASSWORD=